---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Maître Gabard — Avocat au Barreau de Bordeaux',
  description = 'Avocat en droit du travail. Consultations sur rendez-vous. Défense de vos droits avec rigueur et engagement.',
  canonical = 'https://avocat-gabard.fr/',
  ogImage = '/images/og-image.webp',
} = Astro.props;

const siteName = 'Maître Gabard';
---

<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Primaire -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:locale"      content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />

    <!-- Favicon -->
    <!-- 1. Variantes dark/light EN PREMIER (priorité max) -->
    <link rel="icon" type="image/png" href="/images/favicon-dark.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/images/favicon-light.png" media="(prefers-color-scheme: dark)" />

    <!-- 2. Fallback .ico pour vieux navigateurs (IE, etc.) -->
    <!-- <link rel="shortcut icon" href="/images/favicon.ico" /> -->

    <!-- 3. Apple Touch Icon (iOS) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />

    <!-- 4. Manifest (PWA / Android) -->
    <link rel="manifest" href="/images/site.webmanifest" />

    <!-- Préchargement fonts critiques -->
    <link
      rel="preload"
      href="/fonts/Instrument_Serif/InstrumentSerif-Regular.ttf"
      as="font"
      type="font/truetype"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/Outfit/Outfit-Regular.ttf"
      as="font"
      type="font/truetype"
      crossorigin="anonymous"
    />

    <!-- Données structurées (Schema.org — LegalService) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LegalService",
        "name": "Maître Gabard – Avocate",
        "description": "Avocate au Barreau de Bordeaux, orientée droit du travail, droit des contrats, droits de la sécurité sociale.",
        "url": "https://avocat-gabard.fr",
        "telephone": "+33-6-71-39-73-48",
        "email": "mathilde.gabard@avocat.fr",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "21 rue du Tondu",
          "addressLocality": "Bordeaux",
          "postalCode": "33000",
          "addressCountry": "FR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 44.8378,
          "longitude": -0.5792
        },
        "areaServed": {
          "@type": "City",
          "name": "Bordeaux"
        },
        "memberOf": {
          "@type": "Organization",
          "name": "Barreau de Bordeaux"
        },
        "sameAs": [
          "https://www.barreau-bordeaux.fr/",
          "https://avocat-gabard.com"
        ]
      }
    </script>
</head>

<body>
<slot />
</body>
</html>