---
// Hero.astro
// Remplace les placeholders :
//   HERO_IMAGE        → ton image .webp dans /images/
//   HERO_TITLE        → accroche principale
//   GOOGLE_MAPS_URL   → lien Google Maps du cabinet
//   ADRESSE           → adresse complète affichée

import ArrowButton from "./ArrowButton.astro"
---

<section id="accueil" class="hero">

    <!-- Image de fond -->
    <div class="hero-bg">
        <img
                src="/images/tingey-injury-law-firm-DZpc4UY8ZtY-unsplash.webp"
                alt="Femme tenant une balance et une statue dépée pendant la journée"
                class="hero-img"
                fetchpriority="high"
                decoding="async"
        />
        <!-- Dégradé sombre -->
        <div class="hero-overlay"></div>
    </div>

    <!-- Contenu centré -->
    <div class="hero-content">

        <p class="hero-eyebrow">Avocat au Barreau de Bordeaux</p>

        <h1 class="hero-title">
            La défense de vos droits,<br />
            avec rigueur et engagement.
        </h1>

        <!-- Adresse cliquable Google Maps -->
        <a
                href="https://maps.google.com/?q=21+Rue+du+Tondu,+33000+Bordeaux"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-address"
                aria-label="Voir l'adresse du cabinet sur Google Maps"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
            </svg>
            21 rue du Tondu, 33000 Bordeaux
        </a>

        <!-- CTA -->
        <ArrowButton label="première consultation" href="#contact" variant="white" />

    </div>

    <!-- Indicateur scroll -->
    <div class="hero-scroll-hint" aria-hidden="true">
        <span class="scroll-line"></span>
    </div>

</section>

<style>
    /* ── Structure ── */
    .hero {
        position: relative;
        width: 100%;
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    /* ── Image + overlay ── */
    .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    .hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 30%;
        display: block;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
                to top,
                rgba(10, 12, 10, 0.35)  0%,
                rgba(10, 12, 10, 0.55)  40%,
                rgba(10, 12, 10, 0.78)  75%,
                rgba(10, 12, 10, 0.92) 100%
        );
    }

    /* ── Contenu ── */
    .hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding-inline: var(--section-px);
        gap: 0;
        /* Décalage léger vers le haut pour laisser de la place au scroll hint */
        margin-top: -4rem;
    }

    /* Eyebrow */
    .hero-eyebrow {
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 300;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 1.25rem;
        opacity: 0;
        animation: fadeUp 0.8s ease 0.2s forwards;
    }

    /* Titre */
    .hero-title {
        font-family: var(--font-title);
        font-size: clamp(2.75rem, 7vw, 6rem);
        font-weight: 400;
        line-height: 1.1;
        color: #ffffff;
        max-width: 820px;
        margin-bottom: 1.75rem;
        opacity: 0;
        animation: fadeUp 0.9s ease 0.4s forwards;
    }

    /* Adresse */
    .hero-address {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 300;
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        margin-bottom: 3.5rem;
        padding: 0.35rem 0;
        border-bottom: 1px solid transparent;
        transition: color 250ms ease, border-color 250ms ease;
        opacity: 0;
        animation: fadeUp 0.9s ease 0.6s forwards;
    }

    .hero-address svg {
        flex-shrink: 0;
        opacity: 0.7;
        transition: opacity 250ms ease;
    }

    .hero-address:hover {
        color: rgba(255, 255, 255, 0.9);
        border-bottom-color: rgba(255, 255, 255, 0.35);
    }

    .hero-address:hover svg {
        opacity: 1;
    }

    /* ── CTA ── */
    .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-family: var(--font-body);
        font-size: 0.9375rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        color: var(--color-text);
        background-color: #ffffff;
        text-decoration: none;
        padding: 1rem 2rem;
        border-radius: 0;           /* Pas d'arrondi */
        border: none;
        cursor: pointer;
        overflow: hidden;
        opacity: 0;
        animation: fadeUp 0.9s ease 0.8s forwards;
        transition: background-color 250ms ease, color 250ms ease;
    }

    .hero-cta:hover {
        background-color: var(--color-accent);
        color: #ffffff;
    }

    /* Icône — rotation au survol */
    .hero-cta-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .hero-cta:hover .hero-cta-icon {
        transform: rotate(45deg);   /* ArrowUpRight → ArrowRight : -45° depuis l'origine */
    }

    /* ── Scroll hint ── */
    .hero-scroll-hint {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        opacity: 0;
        animation: fadeIn 1s ease 1.4s forwards;
    }

    .scroll-line {
        display: block;
        width: 1px;
        height: 56px;
        background: linear-gradient(
                to bottom,
                rgba(255,255,255,0) 0%,
                rgba(255,255,255,0.5) 100%
        );
        animation: scrollPulse 2s ease-in-out 1.6s infinite;
        transform-origin: top;
    }

    /* ── Animations ── */
    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    @keyframes scrollPulse {
        0%, 100% { transform: scaleY(1);   opacity: 0.5; }
        50%       { transform: scaleY(0.5); opacity: 1;   }
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
        .hero-title {
            font-size: clamp(2.25rem, 10vw, 3.5rem);
        }

        .hero-cta {
            width: 100%;
            justify-content: center;
        }
    }
</style>