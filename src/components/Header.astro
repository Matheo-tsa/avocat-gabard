---
import ArrowButton from "./ArrowButton.astro";

const navLinks = [
  { label: 'accueil',      href: '/#accueil'     },
  { label: 'à propos',     href: '/#a-propos'    },
  { label: 'compétences',  href: '/#competences' },
  { label: 'honoraires',   href: '/#honoraires'  },
];
---

<header id="header">
    <div class="header-inner container">

        <!-- Logo / identité -->
        <a href="/#accueil" class="header-logo" aria-label="Retour à l'accueil">
            <span class="logo-title">GABARD</span>
            <span class="logo-sub">avocat.</span>
        </a>

        <!-- Navigation desktop + CTA groupés à droite -->
        <div class="header-right">
            <nav class="header-nav" aria-label="Navigation principale">
                <ul>
                  {navLinks.map(link => (
                          <li>
                              <a href={link.href} class="nav-link">{link.label}</a>
                          </li>
                  ))}
                </ul>
            </nav>

            <!-- CTA + burger -->
            <div class="header-actions">
                <a href="/#contact" class="header-cta">prendre rendez-vous</a>
                <button
                  class="burger"
                  id="burger-btn"
                  aria-label="Ouvrir le menu"
                  aria-expanded="false"
                  aria-controls="mobile-menu"
                >
                  <span></span>
                  <span></span>
                  <span></span>
                </button>
            </div>
        </div>
    </div>

    <!-- Menu mobile -->
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <nav aria-label="Navigation mobile">
            <ul>
              {navLinks.map(link => (
                      <li>
                          <a href={link.href} class="mobile-nav-link">{link.label}</a>
                      </li>
              ))}
                <li>
                    <a href="/#contact" class="btn-primary mobile-cta">Prendre rendez-vous</a>
                </li>
            </ul>
        </nav>
    </div>
</header>

<style>
    /* ── Structure ── */
    #header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background-color: transparent;
        transition: background-color 300ms ease,
        box-shadow 300ms ease,
        padding 300ms ease;
    }

    #header.scrolled {
        background-color: var(--color-bg);
        box-shadow: 0 1px 0 var(--color-border);
    }

    .header-inner {
        display: flex;
        align-items: center;
        gap: 2rem;
        padding-block: 1.5rem;
        transition: padding-block 300ms ease;
    }

    /* Groupe nav + CTA poussé à droite */
    .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-left: auto;
    }

    #header.scrolled .header-inner {
        padding-block: 1rem;
    }

    /* ── Logo ── */
    .header-logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.1rem;
        text-decoration: none;
        flex-shrink: 0;
    }

    /* ── Actions ── */
    .header-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-shrink: 0;
    }

    /* ── Logo — blanc sur hero, bascule au scroll ── */
    .logo-title {
        font-family: var(--font-logo-name);
        font-size: 1.375rem;
        color: #ffffff;
        text-transform: uppercase;
        line-height: 1;
        letter-spacing: 2px;
        transition: color var(--transition-base);
    }

    .logo-sub {
        font-family: var(--font-logo-title);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: rgb(255, 255, 255);
        transition: color var(--transition-base);
    }

    .header-logo:hover .logo-title {
        color: var(--color-gold);
    }

    #header.scrolled .logo-title {
        color: var(--color-accent-lt);
    }

    #header.scrolled .logo-sub {
        color: var(--color-accent-lt);
    }

    /* ── Nav desktop — blanc ── */
    .header-nav ul {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .nav-link {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 400;
        letter-spacing: 0.02em;
        color: rgba(255, 255, 255, 0.85);
        padding: 0.5rem 0.875rem;
        border-radius: var(--radius-sm);
        position: relative;
        transition: color var(--transition-base);
    }

    .nav-link::after {
        content: '';
        position: absolute;
        bottom: 4px;
        left: 0.875rem;
        right: 0.875rem;
        height: 1px;
        background-color: #ffffff;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 250ms ease;
    }

    .nav-link:hover {
        color: #ffffff;
    }

    .nav-link:hover::after {
        transform: scaleX(1);
    }

    /* Quand le header est scrollé → liens sombres */
    #header.scrolled .nav-link {
        color: var(--color-text);
    }

    #header.scrolled .nav-link::after {
        background-color: var(--color-accent);
    }

    #header.scrolled .nav-link:hover {
        color: var(--color-accent);
    }

    /* ── CTA — fond blanc, texte noir, sans arrondi ── */
    .header-cta {
        font-family: var(--font-body);
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        padding: 0.6rem 1.375rem;
        background-color: #ffffff;
        color: var(--color-text);
        text-decoration: none;
        border-radius: 0;
        display: inline-block;
        transition: background-color var(--transition-base),
        color var(--transition-base),
        transform var(--transition-base);
    }

    .header-cta:hover {
        background-color: var(--color-accent);
        color: #ffffff;
        transform: translateY(-1px);
    }

    /* Quand scrollé : le blanc sur blanc est visible grâce au fond ivoire du header */
    #header.scrolled .header-cta {
        background-color: var(--color-accent);
        color: #ffffff;
    }

    #header.scrolled .header-cta:hover {
        background-color: var(--color-accent-lt);
    }

    /* ── Burger ── */
    .burger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 4px;
        border-radius: var(--radius-sm);
        transition: background-color var(--transition-base);
    }

    .burger:hover {
        background-color: rgba(44, 74, 62, 0.07);
    }

    .burger span {
        display: block;
        height: 1.5px;
        background-color: #ffffff;
        border-radius: 2px;
        transition: transform 300ms ease, opacity 300ms ease, width 300ms ease;
        transform-origin: center;
    }

    #header.scrolled .burger span {
        background-color: var(--color-text);
    }

    .burger span:nth-child(1) { width: 22px; }
    .burger span:nth-child(2) { width: 16px; }
    .burger span:nth-child(3) { width: 22px; }

    .burger[aria-expanded="true"] span:nth-child(1) {
        transform: translateY(6.5px) rotate(45deg);
        width: 22px;
    }
    .burger[aria-expanded="true"] span:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }
    .burger[aria-expanded="true"] span:nth-child(3) {
        transform: translateY(-6.5px) rotate(-45deg);
        width: 22px;
    }

    /* ── Menu mobile ── */
    .mobile-menu {
        display: none;
        overflow: hidden;
        max-height: 0;
        background-color: var(--color-surface);
        border-top: 1px solid var(--color-border);
        transition: max-height 350ms ease;
    }

    .mobile-menu.open {
        max-height: 480px;
    }

    .mobile-menu nav ul {
        list-style: none;
        padding: 1.5rem var(--section-px);
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .mobile-nav-link {
        display: block;
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 400;
        color: var(--color-text);
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--color-border);
        transition: color var(--transition-base), padding-left var(--transition-base);
    }

    .mobile-nav-link:hover {
        color: var(--color-accent);
        padding-left: 0.5rem;
    }

    .mobile-cta {
        display: block;
        text-align: center;
        margin-top: 1rem;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .header-nav,
        .header-cta {
            display: none;
        }

        .burger {
            display: flex;
        }

        .mobile-menu {
            display: block;
        }
    }
</style>

<script>
  const header    = document.getElementById('header')!;
  const burgerBtn = document.getElementById('burger-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  // Scroll → header opaque
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // Burger toggle
  burgerBtn.addEventListener('click', () => {
    const isOpen = burgerBtn.getAttribute('aria-expanded') === 'true';
    burgerBtn.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu.setAttribute('aria-hidden', String(isOpen));
    mobileMenu.classList.toggle('open', !isOpen);
  });

  // Fermer le menu mobile au clic sur un lien
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      burgerBtn.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileMenu.classList.remove('open');
    });
  });

  // Active link au scroll
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks  = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => {
          link.classList.toggle(
            'active',
            link.getAttribute('href') === `#${entry.target.id}`
          );
        });
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });

  sections.forEach(s => observer.observe(s));
</script>