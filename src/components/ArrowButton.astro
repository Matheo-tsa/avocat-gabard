---
// ArrowButton.astro
// Props :
//   label    — texte du bouton
//   href     — lien (ancre ou URL)
//   variant  — "accent" (fond vert, texte blanc) | "white" (fond blanc, texte noir)
//   external — ouvre dans un nouvel onglet si true

interface Props {
  label: string;
  href: string;
  variant?: 'accent' | 'white';
  external?: boolean;
}

const {
  label,
  href,
  variant = 'accent',
  external = false,
} = Astro.props;
---

<a
        href={href}
        class={`arrow-btn arrow-btn--${variant}`}
        {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
        aria-label={label}
>
    <span class="arrow-btn__label">{label}</span>
    <span class="arrow-btn__icon" aria-hidden="true">
    <!-- Lucide ArrowUpRight -->
    <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
    >
      <path d="M7 7h10v10"/>
      <path d="M7 17 17 7"/>
    </svg>
  </span>
</a>

<style>
    .arrow-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-family: var(--font-body);
        font-size: 0.9375rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        text-decoration: none;
        padding: 1rem 2rem;
        border-radius: 0;
        cursor: pointer;
        transition: background-color 250ms ease, color 250ms ease, transform 250ms ease;
    }

    /* Variante accent — fond vert, texte blanc */
    .arrow-btn--accent {
        background-color: var(--color-accent);
        color: #ffffff;
    }

    .arrow-btn--accent:hover {
        background-color: var(--color-accent-lt);
        color: #ffffff;
        transform: translateY(-1px);
    }

    /* Variante white — fond blanc, texte noir */
    .arrow-btn--white {
        background-color: #ffffff;
        color: var(--color-text);
    }

    .arrow-btn--white:hover {
        background-color: var(--color-accent);
        color: #ffffff;
        transform: translateY(-1px);
    }

    /* Icône — rotation au survol */
    .arrow-btn__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .arrow-btn:hover .arrow-btn__icon {
        transform: rotate(45deg);
    }
</style>