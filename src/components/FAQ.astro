---
const faqs = [
  {
    question: 'Intervenez-vous uniquement à Bordeaux et à Angoulême ?',
    answer:
      "Le cabinet est situé à Bordeaux, mais peut intervenir sur l’ensemble du territoire français selon la nature du dossier et la juridiction compétente. En droit du travail, j’interviens principalement à Bordeaux et à Angoulême, tout en pouvant assurer la défense de vos intérêts partout en France.",
  },
  {
    question: 'Le premier rendez-vous est-il payant ?',
    answer:
      "Le premier rendez-vous est facturé 60 € TTC. Toutefois, ce montant n’est pas facturé en cas d’ouverture de dossier à l’issue de la consultation.",
  },
  {
    question: "Comment se déroule la première consultation ?",
    answer:
      "La première consultation permet d’échanger sur votre situation et d’analyser les éléments de votre dossier. Elle a pour objectif de comprendre vos besoins, d’évaluer l’opportunité d’une procédure et de définir la stratégie la plus adaptée à la défense de vos intérêts.",
  },
  {
    question: 'Quels documents préparer pour un premier rendez-vous ?',
    answer:
    "Il est recommandé de transmettre ou d’apporter l’ensemble des documents utiles à l’étude de votre dossier (contrat de travail, courriers, échanges de mails, bulletins de salaire, etc.).",
  },
  {
    question: 'Les honoraires peuvent-ils être pris en charge ?',
      answer:
    "Si vous bénéficiez d’une assurance de protection juridique, une prise en charge totale ou partielle des honoraires peut être envisagée par votre assureur. Le cabinet peut également vous renseigner sur l’aide juridictionnelle.",
  },
  {
    question: 'Est-ce que les consultations ont obligatoirement lieu au cabinet ?',
      answer:
    "Non. Les consultations peuvent avoir lieu au cabinet, mais également par téléphone selon vos préférences et les besoins du dossier.",
  },
];
---

<section id="faq" class="faq section">
    <div class="container faq-inner">

        <!-- Colonne gauche : titre fixe -->
        <div class="faq-aside">
            <p class="faq-eyebrow">Questions fréquentes</p>
            <h2 class="faq-title">
                Vous avez<br />des questions ?
            </h2>
            <p class="faq-subtitle">
                Retrouvez ici les réponses aux interrogations les plus courantes. Pour toute autre question, n'hésitez pas à me contacter directement.
            </p>
            <a href="#contact" class="faq-cta">
                <span>Poser une question</span>
                <span class="faq-cta__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
          </svg>
        </span>
            </a>
        </div>

        <!-- Colonne droite : accordéon -->
        <div class="faq-list" role="list">
          {faqs.map((faq, i) => (
                  <div class="faq-item" role="listitem" style={`--delay: ${i * 0.08}s`}>
                      <button
                              class="faq-question"
                              aria-expanded="false"
                              aria-controls={`faq-answer-${i}`}
                              id={`faq-btn-${i}`}
                              type="button"
                      >
                          <span class="faq-question__text">{faq.question}</span>
                          <span class="faq-question__icon" aria-hidden="true">
              <!-- Lucide Plus → transformé en X à l'ouverture via CSS -->
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path class="icon-h" d="M5 12h14"/>
                <path class="icon-v" d="M12 5v14"/>
              </svg>
            </span>
                      </button>

                      <div
                              class="faq-answer"
                              id={`faq-answer-${i}`}
                              role="region"
                              aria-labelledby={`faq-btn-${i}`}
                              hidden
                      >
                          <p>{faq.answer}</p>
                      </div>
                  </div>
          ))}
        </div>

    </div>
</section>

<style>
    /* ── Section ── */
    .faq {
        background-color: var(--color-bg);
    }

    .faq-inner {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 5rem;
        align-items: start;
    }

    /* ── Aside gauche ── */
    .faq-aside {
        position: sticky;
        top: 6rem; /* compense le header fixe */
    }

    .faq-eyebrow {
        font-family: var(--font-body);
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-accent);
        margin-bottom: 1rem;
    }

    .faq-title {
        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--color-text);
        line-height: 1.1;
        margin-bottom: 1.25rem;
    }

    .faq-subtitle {
        font-size: 0.9375rem;
        color: var(--color-muted);
        line-height: 1.75;
        margin-bottom: 2rem;
    }

    /* CTA texte avec flèche */
    .faq-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-body);
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--color-accent);
        text-decoration: none;
        border-bottom: 1.5px solid var(--color-accent);
        padding-bottom: 2px;
        transition: color var(--transition-base), border-color var(--transition-base);
    }

    .faq-cta:hover {
        color: var(--color-accent-lt);
        border-color: var(--color-accent-lt);
    }

    .faq-cta__icon {
        display: inline-flex;
        transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .faq-cta:hover .faq-cta__icon {
        transform: rotate(45deg);
    }

    /* ── Accordéon ── */
    .faq-list {
        display: flex;
        flex-direction: column;
    }

    .faq-item {
        border-bottom: 1.5px solid var(--color-border);
        opacity: 0;
        transform: translateY(16px);
        transition:
                opacity 0.5s ease var(--delay),
                transform 0.5s ease var(--delay);
    }

    .faq-item:first-child {
        border-top: 1.5px solid var(--color-border);
    }

    .faq-item.visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* Bouton question */
    .faq-question {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        background: none;
        border: none;
        padding: 1.5rem 0;
        cursor: pointer;
        text-align: left;
        font-family: var(--font-body);
    }

    .faq-question__text {
        font-family: var(--font-title);
        font-size: 1.125rem;
        font-weight: 400;
        color: var(--color-text);
        line-height: 1.35;
        transition: color var(--transition-base);
    }

    .faq-question:hover .faq-question__text {
        color: var(--color-accent);
    }

    /* Icône +/× */
    .faq-question__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        border: 1.5px solid var(--color-border);
        border-radius: 50%;
        color: var(--color-accent);
        transition: background-color 250ms ease,
        border-color 250ms ease,
        transform 350ms ease;
    }

    .faq-question:hover .faq-question__icon {
        background-color: rgba(44, 74, 62, 0.06);
        border-color: var(--color-accent);
    }

    /* Rotation de l'icône à l'ouverture */
    .faq-question[aria-expanded="true"] .faq-question__icon {
        transform: rotate(45deg);
        background-color: var(--color-accent);
        border-color: var(--color-accent);
        color: #ffffff;
    }

    /* Barre verticale du + qui disparaît → devient × */
    .icon-v {
        transform-origin: center;
        transition: transform 300ms ease, opacity 300ms ease;
    }

    /* Réponse */
    .faq-answer {
        overflow: hidden;
        /* max-height animée via JS */
    }

    .faq-answer p {
        padding: 0 2.5rem 1.75rem 0;
        font-size: 0.9375rem;
        color: var(--color-muted);
        line-height: 1.8;
        margin: 0;
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
        .faq-inner {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .faq-aside {
            position: static;
        }
    }
</style>

<script>
  // ── Entrée au scroll ──
  const items = document.querySelectorAll('.faq-item');

  const scrollObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        scrollObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  items.forEach(item => scrollObserver.observe(item));

  // ── Accordéon ──
  document.querySelectorAll<HTMLButtonElement>('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const isOpen    = btn.getAttribute('aria-expanded') === 'true';
      const answerId  = btn.getAttribute('aria-controls')!;
      const answer    = document.getElementById(answerId)!;

      // Ferme tous les autres
      document.querySelectorAll<HTMLButtonElement>('.faq-question').forEach(other => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          const otherAnswer = document.getElementById(other.getAttribute('aria-controls')!)!;
          otherAnswer.style.maxHeight = '0';
          setTimeout(() => { otherAnswer.hidden = true; }, 300);
        }
      });

      // Toggle courant
      if (isOpen) {
        btn.setAttribute('aria-expanded', 'false');
        answer.style.maxHeight = '0';
        setTimeout(() => { answer.hidden = true; }, 300);
      } else {
        btn.setAttribute('aria-expanded', 'true');
        answer.hidden = false;
        answer.style.maxHeight = '0';
        // Force reflow avant l'animation
        answer.getBoundingClientRect();
        answer.style.transition = 'max-height 350ms ease';
        answer.style.maxHeight  = answer.scrollHeight + 'px';
      }
    });
  });
</script>